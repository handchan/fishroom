# Copy to ".env" and fill in to enable cloud sync. Leave unset to stay 100%
# on-device (the app works fully offline without these).
#
# The anon key is a PUBLISHABLE key — it is safe to expose in client code.
# All access is enforced by Postgres Row-Level Security (see docs/INTEGRATION.md):
# the public/anon role can only READ rows you've marked shared, never write.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# The slug your personal site (hengchengyu.com/aquarium) will read from.
VITE_AQUARIUM_SLUG=hengchengyu
